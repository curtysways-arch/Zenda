# =============================================================================
# ZENDA – Variables de Entorno (.env.example)
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS – PostgreSQL (producción)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://zenda_user:STRONG_PASSWORD@localhost:5432/zenda_db?schema=public"

# -----------------------------------------------------------------------------
# NEXT AUTH
# -----------------------------------------------------------------------------
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_32_CHARS_# URL pública de la aplicación (sin barra final)
NEXTAUTH_URL="https://tu-dominio.com"

# -----------------------------------------------------------------------------
# URLs PÚBLICAS
# -----------------------------------------------------------------------------
# URL base de la app, usada en links de WhatsApp, emails y notificaciones
NEXT_PUBLIC_APP_URL="https://tu-dominio.com"
# URL base para servir archivos subidos (storage local)
# Debe ser la misma que NEXTAUTH_URL / dominio principal
NEXT_PUBLIC_BASE_URL="https://tu-dominio.com"

# -----------------------------------------------------------------------------
# BOT WHATSAPP (proceso separado, Baileys)
# -----------------------------------------------------------------------------
# URL interna del servidor HTTP del bot (no expuesta al exterior)
BOT_HTTP_URL="http://127.0.0.1:3001"

# Teléfono del administrador de WhatsApp (formato internacional, sin +)
# Ejemplo: 5491122334455
WHATSAPP_PHONE=""

# (Opcional) Webhook alternativo para notificaciones de mensajes
NOTIFICATIONS_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# STORAGE LOCAL (uploads / imágenes)
# -----------------------------------------------------------------------------
# Ruta ABSOLUTA donde se guardan los archivos subidos por los negocios
# En producción: /var/www/zenda/storage/uploads
STORAGE_PATH="/var/www/zenda/storage/uploads"

# Provider de storage: 'local' (implementado) | 's3' | 'r2' (futuro)
STORAGE_PROVIDER="local"

# -----------------------------------------------------------------------------
# FIREBASE – Cliente Web (NEXT_PUBLIC_* son visibles en el navegador)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="tu-proyecto.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="tu-proyecto"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="tu-proyecto.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abcdef"
NEXT_PUBLIC_FIREBASE_VAPID_KEY="BK..."

# -----------------------------------------------------------------------------
# FIREBASE ADMIN – Servidor (push notifications, nunca exponer al cliente)
# Obtén estas credenciales desde Firebase Console → Configuración del proyecto
# → Cuentas de servicio → Generar nueva clave privada
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID="tu-proyecto"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com"
# La clave privada debe tener los saltos de línea como \n literales:
# Ejemplo: "-----BEGIN PRIVATE KEY-----\nMIIEvAIB...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# NODE ENV (no cambiar manualmente)
# -----------------------------------------------------------------------------
NODE_ENV="production"
