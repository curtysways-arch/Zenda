generator client {
  provider = "prisma-client-js"
}

// ─── ENUMS DE SISTEMA DE PREMIOS ──────────────────────────────────────────────

enum RewardDeliveryType {
  AUTOMATICO
  MANUAL
}

enum RewardType {
  CUPON
  SERVICIO_GRATIS
  PRODUCTO
  REGALO
  PUNTOS
  CASHBACK
  BADGE
  PERSONALIZADO
}

enum RewardStatus {
  DISPONIBLE
  RESERVADO
  CANJEADO
  PENDIENTE_ENTREGA
  SOLICITADO
  LISTO_PARA_RETIRAR
  ENTREGADO
  CANCELADO
  VENCIDO
}

datasource db {
  provider = "postgresql"
}

model Attendance {
  id               String           @id
  scheduleId       String
  enrollmentId     String
  date             DateTime
  status           String
  CourseEnrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id])
  CourseSchedule   CourseSchedule   @relation(fields: [scheduleId], references: [id])
}

model AutomaticDiscount {
  id                 String   @id
  businessId         String
  serviceId          String?
  enabled            Boolean  @default(false)
  discountPercentage Float
  daysOfWeek         String
  startTime          String
  endTime            String
  hoursBefore        Int
  createdAt          DateTime @default(now())
  imageMediaId       String?
  imageMedia         Media?   @relation("AutomaticDiscountImage", fields: [imageMediaId], references: [id])
  updatedAt          DateTime
  Negocio            Negocio  @relation(fields: [businessId], references: [id])

  @@unique([businessId, serviceId])
}

model Bloqueo {
  id         String   @id
  fecha      DateTime
  horaInicio String
  horaFin    String
  motivo     String?
  serviceId  String?
  staffId    String?
  negocioId  String
  createdAt  DateTime @default(now())
  Service    Service? @relation(fields: [serviceId], references: [id])
  Staff      Staff?   @relation(fields: [staffId], references: [id])
  Negocio    Negocio  @relation(fields: [negocioId], references: [id])
}

model BotLog {
  id               String   @id
  phone            String
  message_received String?
  message_sent     String?
  action_taken     String?
  timestamp        DateTime @default(now())
}

model Service {
  id                 String               @id
  nombre             String
  duracion           Int                  @default(60)
  precio             Float?
  estaActivo         Boolean              @default(true)
  negocioId          String
  imageMediaId       String?
  imageMedia         Media?               @relation("ServiceImage", fields: [imageMediaId], references: [id])
  ubicacionId        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  extraInfo          Json?
  Bloqueo            Bloqueo[]
  Negocio            Negocio              @relation(fields: [negocioId], references: [id])
  Ubicacion          Ubicacion?           @relation(fields: [ubicacionId], references: [id])
  CourseSchedule     CourseSchedule[]
  Imagen             Imagen[]
  Appointment        Appointment[]
  Resultado          Resultado[]
  PromotionToService PromotionToService[]
  Staff              Staff[]              @relation("StaffServices")
  LoyaltyReward      LoyaltyReward[]     // Premios de tipo SERVICIO_GRATIS vinculados a este servicio
  ReferralCampaign   ReferralCampaign[]  // Campañas de tipo SERVICIO_GRATIS vinculadas a este servicio

  @@map("Cancha")
}

model Cliente {
  id             String        @id
  nombre         String
  telefono       String
  email          String?
  negocioId      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  imagenUrl       String?
  fechaNacimiento DateTime?
  Negocio        Negocio       @relation(fields: [negocioId], references: [id])
  ratingPromedio Float         @default(0)
  totalReviews   Int           @default(0)
  Appointment    Appointment[]

  @@unique([telefono, negocioId])
}

model CommentResultado {
  id          String    @id
  resultadoId String
  userName    String
  userAvatar  String?
  content     String
  approved    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  userId      String?
  Resultado   Resultado @relation(fields: [resultadoId], references: [id], onDelete: Cascade)

  @@index([resultadoId])
}

model Configuracion {
  id        String  @id
  clave     String
  valor     String
  negocioId String
  Negocio   Negocio @relation(fields: [negocioId], references: [id])

  @@unique([clave, negocioId])
}

model Course {
  id               String             @id
  name             String
  description      String?
  imageUrl         String? // legacy
  imageMediaId     String?
  imageMedia       Media?             @relation("CourseImage", fields: [imageMediaId], references: [id])
  min_age          Int?
  max_age          Int?
  coach            String?
  price            Float
  payment_type     String
  capacity         Int
  status           String             @default("active")
  start_date       DateTime?
  end_date         DateTime?
  content          String?
  businessId       String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  instructor_id    String?
  Negocio          Negocio            @relation(fields: [businessId], references: [id])
  Usuario          Usuario?           @relation(fields: [instructor_id], references: [id])
  CourseEnrollment CourseEnrollment[]
  CourseSchedule   CourseSchedule[]
  course_classes   course_classes[]
}

model CourseEnrollment {
  id                String              @id
  studentId         String?
  userId            String?
  courseId          String
  businessId        String?
  student_name      String?
  student_age       Int?
  guardian_name     String?
  guardian_phone    String?
  guardian_email    String?
  enrollment_date   DateTime            @default(now())
  status            String              @default("pending")
  comments          String?
  Attendance        Attendance[]
  Course            Course              @relation(fields: [courseId], references: [id])
  Usuario           Usuario?            @relation(fields: [userId], references: [id])
  Student           Student?            @relation(fields: [studentId], references: [id])
  CoursePayment     CoursePayment[]
  course_attendance course_attendance[]
}

model CoursePayment {
  id               String           @id
  enrollmentId     String
  amount           Float
  payment_date     DateTime         @default(now())
  payment_type     String
  status           String           @default("completed")
  CourseEnrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id])
}

model CourseSchedule {
  id          String       @id
  day_of_week Int
  start_time  String
  end_time    String
  serviceId   String
  courseId    String
  title       String?
  Attendance  Attendance[]
  Course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Service     Service      @relation(fields: [serviceId], references: [id])
}

model GlobalConfig {
  id    String @id
  clave String @unique
  valor String
}

model Imagen {
  id        String   @id
  url       String
  publicId  String?
  tipo      String   @default("GALERIA")
  negocioId String
  serviceId String?
  esBanner  Boolean  @default(false)
  createdAt DateTime @default(now())
  Negocio   Negocio  @relation(fields: [negocioId], references: [id])
  Service   Service? @relation(fields: [serviceId], references: [id])
}

model Media {
  id         String  @id @default(uuid())
  businessId String
  url        String // public URL (served via API)
  fileKey    String // path or key in storage provider
  provider   String // e.g., 'local', 's3', 'r2'
  mimeType   String
  size       Int
  width      Int?
  height     Int?
  category   String? // logo, banner, service, staff,  // Relaciones opcionales (se añaden según sea necesario)
  Negocio    Negocio @relation("NegocioMedia", fields: [businessId], references: [id])

  // Más relaciones pueden añadirse en el futuro
  promotions         Promotion[]         @relation("PromotionImage")
  services           Service[]           @relation("ServiceImage")
  staff              Staff[]             @relation("StaffImage")
  courses            Course[]            @relation("CourseImage")
  pages              Page[]              @relation("PageImage")
  automaticDiscounts AutomaticDiscount[] @relation("AutomaticDiscountImage")
}

model LikeResultado {
  id          String    @id
  resultadoId String
  userId      String?
  sessionId   String?
  createdAt   DateTime  @default(now())
  Resultado   Resultado @relation(fields: [resultadoId], references: [id], onDelete: Cascade)

  @@index([resultadoId])
}

model Negocio {
  id                     String                @id
  nombre                 String
  propietario            String?
  slug                   String                @unique
  whatsapp               String?
  direccion              String?
  ciudad                 String?
  logoUrl                String?
  precioHora             Float
  horarioApertura        String
  horarioCierre          String
  statusOverride         String                @default("AUTO")
  configuracion          Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime
  pagosActivos           Boolean               @default(false)
  pagoPorcentaje         Int                   @default(50)
  mercadoPagoPublicKey   String?
  mercadoPagoAccessToken String?
  colorPrimario          String?               @default("#1dc95c")
  colorSecundario        String?               @default("#112117")
  colorTerciario         String?               @default("#7B68EE")
  colorNeutral           String?               @default("#FFF5F5")
  colorTexto             String?               @default("#ffffff")
  colorSubTexto          String?               @default("#475569")
  heroTitulo             String?
  heroSubtitulo          String?
  mensajeBienvenida      String?
  saludoTitulo           String?               @default("Hola")
  nombreFallback         String?               @default("Radiante")
  tieneCafeteria         Boolean               @default(false)
  tieneParking           Boolean               @default(false)
  tieneWifi              Boolean               @default(false)
  tieneVestidores        Boolean               @default(false)
  tieneTienda            Boolean               @default(false)
  moduloTorneos          Boolean               @default(false)
  instagramUrl           String?
  facebookUrl            String?
  tiktokUrl              String?
  emailContacto          String?
  websiteUrl             String?
  youtubeUrl             String?
  faqUrl                 String?
  terminosUrl            String?
  privacidadUrl          String?
  estado                 String                @default("ACTIVO")
  isDemo                 Boolean               @default(false)
  mostrarPrecios         Boolean               @default(true)
  appointmentsUsed       Int                   @default(0)
  billingStatus          String                @default("active")
  planExpiresAt          DateTime?
  statusNote             String?
  AutomaticDiscount      AutomaticDiscount[]
  Bloqueo                Bloqueo[]
  Service                Service[]
  Cliente                Cliente[]
  Configuracion          Configuracion[]
  Course                 Course[]
  Imagen                 Imagen[]
  Page                   Page[]
  Payment                Payment[]
  Promotion              Promotion[]
  PushToken              PushToken[]
  Appointment            Appointment[]
  Resultado              Resultado[]
  Staff                  Staff[]
  Student                Student[]
  Subscriber             Subscriber[]
  SubscriptionHistory    SubscriptionHistory[]
  Suscripcion            Suscripcion?
  Ubicacion              Ubicacion[]
  Usuario                Usuario[]
  media                  Media[]               @relation("NegocioMedia")
  ReferralCampaign       ReferralCampaign[]
  ReferralCode           ReferralCode[]
  ReferralEvent          ReferralEvent[]
  ReferralReward         ReferralReward[]
  UserPoints             UserPoints[]
  PointsHistory          PointsHistory[]
  LoyaltyReward          LoyaltyReward[]
  LoyaltyRedemption      LoyaltyRedemption[]
  Coupon                 Coupon[]
  ClientCoupon           ClientCoupon[]
  AutomationRule         AutomationRule[]
  Notification           Notification[]
  AdminUserNegocio       AdminUserNegocio[]
  Season                 Season[]
  Campaign               Campaign[]
  Quest                  Quest[]
  LevelTier              LevelTier[]
  Badge                  Badge[]
  UserStreak             UserStreak[]
  RewardAudit            RewardAudit[]
  LoyaltyLevels              LoyaltyLevel[]
  LoyaltySeasons             LoyaltySeason[]
  BusinessGlobalMissions     BusinessGlobalMission[]
  GlobalMissionRewardHistory GlobalMissionRewardHistory[]
  Wallets                    Wallet[]
  LeaderboardEntries         LeaderboardEntry[]
  InstalledTemplates         InstalledTemplate[]
  TemplateSnapshots          InstalledTemplateSnapshot[]
  BusinessAchievements       BusinessAchievement[]
  ClientGlobalCampaigns      ClientGlobalCampaignParticipation[]
  ClientGlobalProgress       ClientGlobalQuestProgress[]
  BusinessMissions           BusinessMission[]            // Nuevo sistema de misiones desacoplado
  BusinessInheritances       BusinessInheritance[]        // Capa de herencia del Club Citiox
  paymentMethods             PaymentMethod[]
  orderPayments              OrderPayment[]
  tipoNegocio                String                       @default("RESERVA")
  categoriasProducto         CategoriaProducto[]
  productos                  Producto[]
  pedidos                    Pedido[]
}

model OtpCode {
  id         String   @id
  telefono   String
  businessId String
  code       String
  verified   Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([businessId])
  @@index([telefono])
}

model Page {
  id            String   @id
  businessId    String
  title         String
  slug          String
  contentHtml   String
  featuredImage String? // legacy
  imageMediaId  String?
  imageMedia    Media?   @relation("PageImage", fields: [imageMediaId], references: [id])
  buttonText    String?
  buttonUrl     String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  Negocio       Negocio  @relation(fields: [businessId], references: [id])

  @@unique([businessId, slug])
}

model PagoReserva {
  id            String      @id
  appointmentId String
  monto         Float
  metodo        String?
  referencia    String?
  notas         String?
  fecha         DateTime    @default(now())
  Appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id
  negocio_id  String
  plan_id     String
  monto       Float
  metodo_pago String?
  fecha_pago  DateTime @default(now())
  estado_pago String
  referencia  String?
  comprobante String?
  Negocio     Negocio  @relation(fields: [negocio_id], references: [id])
}

model PendingReservation {
  id             String   @id
  admin_phone    String
  reservation_id String
  status         String   @default("pending")
  created_at     DateTime @default(now())

  @@index([admin_phone, status])
}

model Plan {
  id                                                             String                @id
  name                                                           String
  description                                                    String?
  price                                                          Float
  trial_days                                                     Int                   @default(0)
  max_fields                                                     Int                   @default(100)
  maxStaff                                                       Int                   @default(1)
  max_reservations_per_month                                     Int                   @default(40)
  maxAppointmentsMonthly                                         Int                   @default(40)
  features                                                       Json?
  tournaments_enabled                                            Boolean               @default(false)
  automatic_discounts_enabled                                    Boolean               @default(false)
  courses_module                                                 Boolean               @default(false)
  max_locations                                                  Int                   @default(1)
  is_recommended                                                 Boolean               @default(false)
  isFree                                                         Boolean               @default(false)
  active                                                         Boolean               @default(true)
  activo                                                         Boolean               @default(true)
  created_at                                                     DateTime              @default(now())
  updated_at                                                     DateTime
  SubscriptionHistory_SubscriptionHistory_plan_nuevo_idToPlan    SubscriptionHistory[] @relation("SubscriptionHistory_plan_nuevo_idToPlan")
  SubscriptionHistory_SubscriptionHistory_plan_anterior_idToPlan SubscriptionHistory[] @relation("SubscriptionHistory_plan_anterior_idToPlan")
  Suscripcion                                                    Suscripcion[]
}

model ProcessedMessage {
  message_id String   @id
  phone      String
  created_at DateTime @default(now())
}

model Promotion {
  id                 String               @id
  businessId         String
  titulo             String
  descripcion        String
  precioPromo        Float
  precioAnterior     Float?
  imagenUrl          String // legacy
  imageMediaId       String?
  imageMedia         Media?               @relation("PromotionImage", fields: [imageMediaId], references: [id])
  fechaInicio        DateTime
  fechaFin           DateTime
  estado             String               @default("borrador")
  shareCount         Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  diasValidos        String?
  horaFinValida      String?
  horaInicioValida   String?
  tipoPromo          String?              @default("precio_especial")
  Negocio            Negocio              @relation(fields: [businessId], references: [id])
  PromotionToService PromotionToService[]

  @@index([fechaFin])
  @@index([estado])
  @@index([businessId])
}

model PushToken {
  id         String   @id
  userId     String?
  businessId String?
  token      String   @unique
  device     String?
  createdAt  DateTime @default(now())
  Negocio    Negocio? @relation(fields: [businessId], references: [id])
  Usuario    Usuario? @relation(fields: [userId], references: [id])
}

model Appointment {
  id                  String        @id
  fecha               DateTime
  horaInicio          String
  horaFin             String
  duracion            Int           @default(1)
  estado              String        @default("pending")
  metodoPago          String?
  pagoEstado          String        @default("PENDIENTE")
  pagoId              String?
  total               Float
  pagoAnticipo        Float         @default(0)
  precioOriginal      Float?
  descuentoAplicado   Float?
  comentarios         String?
  clienteId           String
  serviceId           String
  staffId             String?
  negocioId           String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime
  expiresAt           DateTime?
  reminderDaySent     Boolean       @default(false)
  reminder2HSent      Boolean       @default(false)
  created_by_business Boolean       @default(false)
  shareToken          String?       @unique
  usuarioId           String?
  extraServices       Json?
  checkedInAt         DateTime?
  completedAt         DateTime?
  startedAt           DateTime?
  ratingReminder1Sent Boolean       @default(false)
  ratingReminder2Sent Boolean       @default(false)
  pagoReserva         PagoReserva[]
  cliente             Cliente       @relation(fields: [clienteId], references: [id])
  service             Service       @relation(fields: [serviceId], references: [id])
  staff               Staff?        @relation(fields: [staffId], references: [id])
  negocio             Negocio       @relation(fields: [negocioId], references: [id])
  usuario             Usuario?      @relation(fields: [usuarioId], references: [id])
  ratings             Rating[]

  @@map("Reserva")
}

model Resultado {
  id               String             @id
  businessId       String
  serviceId        String?
  staffId          String?
  title            String
  description      String?
  type             String             @default("BEFORE_AFTER")
  beforeImage      String?
  afterImage       String?
  gallery          Json?
  featured         Boolean            @default(false)
  published        Boolean            @default(true)
  showInLanding    Boolean            @default(false)
  clientName       String?
  date             DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  CommentResultado CommentResultado[]
  LikeResultado    LikeResultado[]
  Negocio          Negocio            @relation(fields: [businessId], references: [id])
  Service          Service?           @relation(fields: [serviceId], references: [id])
  Staff            Staff?             @relation(fields: [staffId], references: [id])
}

model RetryMessage {
  id            String   @id
  phone         String
  message       String
  attempts      Int      @default(0)
  next_retry_at DateTime
  created_at    DateTime @default(now())
}

model Role {
  id       String     @id
  name     String     @unique
  UserRole UserRole[]
}

model Staff {
  id             String           @id
  businessId     String
  imageMediaId   String?
  imageMedia     Media?           @relation("StaffImage", fields: [imageMediaId], references: [id])
  name           String
  role           String?
  avatar         String?
  active         Boolean          @default(true)
  workingHours   Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  usuarioId      String?          @unique
  Bloqueo        Bloqueo[]
  Appointment    Appointment[]
  Resultado      Resultado[]
  Negocio        Negocio          @relation(fields: [businessId], references: [id])
  Usuario        Usuario?         @relation(fields: [usuarioId], references: [id])
  StaffException StaffException[]
  StaffSchedule  StaffSchedule[]
  ratingPromedio Float            @default(0)
  totalReviews   Int              @default(0)
  Service           Service[]           @relation("StaffServices")
  ReferralReward    ReferralReward[]
  LoyaltyRedemption LoyaltyRedemption[]
}

model StaffException {
  id          String   @id
  staffId     String
  date        DateTime
  type        String
  customStart String?
  customEnd   String?
  reason      String?
  Staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
}

model StaffSchedule {
  id        String  @id
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  active    Boolean @default(true)
  breaks    String? @default("[]")
  Staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

model Student {
  id                  String             @id
  name                String
  age                 Int?
  representative_name String?
  phone               String?
  email               String?
  businessId          String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime
  CourseEnrollment    CourseEnrollment[]
  Negocio             Negocio            @relation(fields: [businessId], references: [id])
}

model Subscriber {
  id        String   @id
  email     String
  negocioId String
  createdAt DateTime @default(now())
  Negocio   Negocio  @relation(fields: [negocioId], references: [id])

  @@unique([email, negocioId])
}

model SubscriptionHistory {
  id                                              String   @id
  negocio_id                                      String
  plan_anterior_id                                String?
  plan_nuevo_id                                   String
  tipo_cambio                                     String
  fecha_cambio                                    DateTime @default(now())
  admin_id                                        String?
  Plan_SubscriptionHistory_plan_nuevo_idToPlan    Plan     @relation("SubscriptionHistory_plan_nuevo_idToPlan", fields: [plan_nuevo_id], references: [id])
  Plan_SubscriptionHistory_plan_anterior_idToPlan Plan?    @relation("SubscriptionHistory_plan_anterior_idToPlan", fields: [plan_anterior_id], references: [id])
  Negocio                                         Negocio  @relation(fields: [negocio_id], references: [id])
}

model Suscripcion {
  id                    String    @id
  negocioId             String    @unique
  planId                String
  estado                String    @default("trial")
  pagoPendiente         Boolean   @default(false)
  solicitudPlanId       String?
  metodoPago            String?
  fechaInicio           DateTime  @default(now())
  fechaFin              DateTime
  trial_inicio          DateTime? @default(now())
  trial_fin             DateTime?
  renovacion_automatica Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  lastReminderSent      DateTime?
  paymentProvider       String?
  subscriptionId        String?
  customFeatures        Json?
  isFounder             Boolean   @default(false)
  founderPosition       Int?
  lockedPrice           Float?
  Negocio               Negocio   @relation(fields: [negocioId], references: [id])
  Plan                  Plan      @relation(fields: [planId], references: [id])
}

model Ubicacion {
  id               String    @id
  nombre           String
  direccion        String?
  mapUrl           String?
  telefono         String?
  horario          String?
  imagenUrl        String?
  tieneParqueadero Boolean   @default(false)
  tieneTransporte  Boolean   @default(false)
  tieneZonaSegura  Boolean   @default(false)
  tieneAccesoFacil Boolean   @default(false)
  negocioId        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Service          Service[]
  Negocio          Negocio   @relation(fields: [negocioId], references: [id])

  @@unique([nombre, negocioId])
}

model UserRole {
  user_id String
  role_id String
  Role    Role    @relation(fields: [role_id], references: [id], onDelete: Cascade)
  Usuario Usuario @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
}

model Usuario {
  id                     String             @id
  nombre                 String?
  email                  String?            @unique
  password               String?
  phone                  String?            @unique
  role                   String             @default("ADMIN")
  status                 String             @default("verified")
  auth_method            String             @default("credentials")
  created_by             String             @default("manual")
  negocioId              String?
  whatsapp_notifications Boolean            @default(false)
  otp_code               String?
  otp_expiry             DateTime?
  magic_token            String?            @unique
  last_interaction       DateTime?
  last_message_at        DateTime?
  fechaNacimiento        DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime
  Course                 Course[]
  CourseEnrollment       CourseEnrollment[]
  PushToken              PushToken[]
  Appointment            Appointment[]
  Staff                  Staff?
  UserRole               UserRole[]
  Negocio                Negocio?           @relation(fields: [negocioId], references: [id])
  ReferralCode           ReferralCode[]
  ReferralReward         ReferralReward[]
  ReferralEvent          ReferralEvent[]
  UserPoints             UserPoints[]
  PointsHistory          PointsHistory[]
  LoyaltyRedemption      LoyaltyRedemption[]
  CouponUsage            CouponUsage[]
  ClientCoupon           ClientCoupon[]
  Notification           Notification[]
  QuestProgress          QuestProgress[]
  QuestParticipant      QuestParticipant[]
  UserLevel              UserLevel?
  UserBadge              UserBadge[]
  UserStreak             UserStreak[]
  Wallets                Wallet[]
  LeaderboardEntries     LeaderboardEntry[]
  UserAchievements       UserAchievement[]
  ClientGlobalProgress   ClientGlobalQuestProgress[]
  GlobalLevelHistory     GlobalLevelHistory[]
  BusinessMissionProgress BusinessMissionProgress[] // Nuevo sistema de misiones desacoplado
}

model PromotionToService {
  A         String
  B         String
  Promotion Promotion @relation(fields: [A], references: [id], onDelete: Cascade)
  Service   Service   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_PromotionToService_AB_unique")
  @@index([B], map: "_PromotionToService_B_index")
  @@map("_PromotionToService")
}

model course_attendance {
  id               String           @id
  class_id         String
  user_id          String
  status           String           @default("present")
  created_at       DateTime         @default(now())
  CourseEnrollment CourseEnrollment @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course_classes   course_classes   @relation(fields: [class_id], references: [id], onDelete: Cascade)

  @@unique([class_id, user_id])
}

model course_classes {
  id                String              @id
  course_id         String
  title             String
  description       String?
  class_date        DateTime
  created_at        DateTime            @default(now())
  course_attendance course_attendance[]
  Course            Course              @relation(fields: [course_id], references: [id], onDelete: Cascade)
}

model Rating {
  id            String   @id @default(cuid())
  appointmentId String
  raterId       String
  ratedId       String
  raterRole     String // "client" | "professional"
  ratedRole     String // "client" | "professional"
  stars         Int
  comment       String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, raterRole])
}

model PaymentAccount {
  id           String   @id
  banco        String
  numeroCuenta String
  nombreCuenta String // Titular + Tipo
  logo         String? // URL o Base64 del logo del banco
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── SISTEMA DE REFERIDOS ───────────────────────────────────────────────────

model ReferralCampaign {
  id                  String              @id @default(cuid())
  negocioId           String
  nombre              String
  descripcion         String?
  imagenUrl           String?
  activa              Boolean             @default(true)
  tipoRecompensa      String              // Descripción libre (ej. "Masaje gratis", "Camiseta") — compatibilidad histórica
  valorRecompensa     String
  referidosRequeridos Int
  fechaInicio         DateTime            @default(now())
  fechaFin            DateTime?
  limitePremios       Int?                // null = ilimitado
  premiosEntregados   Int                 @default(0)
  rankingActivo       Boolean             @default(false)
  tipoIncentivo       String?             // incentivo para el referido
  valorIncentivo      String?             // ej: "10% descuento", "Bebida gratis"

  // Tipo de entrega y tipo de premio estructurado
  deliveryType        RewardDeliveryType  @default(AUTOMATICO)
  rewardType          RewardType          @default(PERSONALIZADO)
  serviceId           String?             // Para rewardType = SERVICIO_GRATIS: servicio específico
  recompensaImagenUrl String?             // Imagen del premio (premios manuales)

  // Configuración para Fidelización
  estado              String?             @default("ACTIVA") // ACTIVA | PAUSADA | FINALIZADA
  tipoCampana         String?             @default("CLIENTES_NUEVOS")
  diasInactividad     Int?
  maxPremiosPorCliente Int?
  permitirRepetir     Boolean?            @default(false)
  prioridad           Int?                @default(0)
  combinable          Boolean?            @default(false)
  color               String?
  icono               String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  Negocio             Negocio             @relation(fields: [negocioId], references: [id])
  Service             Service?            @relation(fields: [serviceId], references: [id])
  ReferralEvent       ReferralEvent[]
  ReferralReward      ReferralReward[]
}

model ReferralCode {
  id            String          @id @default(cuid())
  userId        String
  negocioId     String
  codigo        String          @unique
  createdAt     DateTime        @default(now())
  Usuario       Usuario         @relation(fields: [userId], references: [id])
  Negocio       Negocio         @relation(fields: [negocioId], references: [id])
  ReferralEvent ReferralEvent[] @relation("ReferralCodeEvents")

  @@unique([userId, negocioId])
}

model ReferralEvent {
  id            String           @id @default(cuid())
  campaignId    String
  codeId        String
  negocioId     String
  referrerId    String           // userId del que invitó
  referredId    String           // userId del invitado
  appointmentId String?
  estado        String           @default("PENDIENTE") // PENDIENTE | VALIDO | INVALIDO
  ipAddress     String?
  userAgent     String?
  rewardId      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  Campaign      ReferralCampaign @relation(fields: [campaignId], references: [id])
  Code          ReferralCode     @relation("ReferralCodeEvents", fields: [codeId], references: [id])
  Negocio       Negocio          @relation(fields: [negocioId], references: [id])
  Usuario       Usuario          @relation(fields: [referrerId], references: [id])
  Reward        ReferralReward?  @relation(fields: [rewardId], references: [id])
}

model ReferralReward {
  id                     String             @id @default(cuid())
  campaignId             String
  negocioId              String
  userId                 String
  estado                 RewardStatus       @default(DISPONIBLE)
  claimCode              String?            @unique // Código de reclamación para premios manuales (ej. PX-8FK29Q)
  fechaEntrega           DateTime?
  staffId                String?
  notas                  String?
  // Campos de auditoría de entrega física y QR seguro
  claimToken             String?            @unique  // UUID interno y oculto para el código QR
  claimTokenExpiresAt    DateTime?          // Fecha de expiración temporal del código QR
  claimTokenRevokedAt    DateTime?          // Fecha en la que el QR fue revocado tras la entrega
  fechaSolicitud         DateTime?
  fechaRetiro            DateTime?
  scanCount              Int                @default(0) // Contador de escaneos/aperturas del QR
  entregadoPorId         String?            // userId o staffId que confirmó la entrega
  fechaEntregaConfirmada DateTime?
  observaciones          String?
  appointmentId          String?            // Para SERVICIO_GRATIS: reserva donde se usó
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  Campaign               ReferralCampaign   @relation(fields: [campaignId], references: [id])
  Negocio                Negocio            @relation(fields: [negocioId], references: [id])
  Usuario                Usuario            @relation(fields: [userId], references: [id])
  Staff                  Staff?             @relation(fields: [staffId], references: [id])
  ReferralEvent          ReferralEvent[]
}

// ─── MOTOR DE FIDELIZACIÓN Y MARKETING ──────────────────────────────────────

model UserPoints {
  id                     String   @id @default(cuid())
  userId                 String
  negocioId              String
  puntos                 Int      @default(0)
  experiencia            Int      @default(0)
  cashback               Float    @default(0.0)
  nivelActualId          String?
  ultimoNivelVistoId     String?
  ultimaTemporadaVistaId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  Usuario                Usuario  @relation(fields: [userId], references: [id])
  Negocio                Negocio  @relation(fields: [negocioId], references: [id])
  
  NivelActual            LoyaltyLevel?  @relation("NivelActual", fields: [nivelActualId], references: [id])
  UltimoNivelVisto       LoyaltyLevel?  @relation("UltimoNivelVisto", fields: [ultimoNivelVistoId], references: [id])
  UltimaTemporadaVista   LoyaltySeason? @relation("UltimaTemporadaVista", fields: [ultimaTemporadaVistaId], references: [id])

  @@unique([userId, negocioId])
}

model PointsHistory {
  id           String   @id @default(cuid())
  userId       String
  negocioId    String
  puntos       Int      // Positivos = acumulación, negativos = canje
  concepto     String   // RESERVA | REFERIDO | CUMPLEANOS | RESENA | COMPARTIR | CANJE | BONO | AJUSTE
  referenciaId String?  // ID del recurso asociado (cita, recompensa, evento, etc.)
  notas        String?
  createdAt    DateTime @default(now())
  Usuario      Usuario  @relation(fields: [userId], references: [id])
  Negocio      Negocio  @relation(fields: [negocioId], references: [id])
}

model LoyaltyReward {
  id                  String              @id @default(cuid())
  negocioId           String
  nombre              String
  descripcion         String?
  imagenUrl           String?
  recompensaImagenUrl String?             // Imagen específica del premio (premios manuales)
  costoPuntos         Int                 @default(0) // 0 = gratis, >0 = canjeable por puntos
  tipo                RewardType          @default(PERSONALIZADO)
  deliveryType        RewardDeliveryType  @default(AUTOMATICO)
  valor               String?             // Valor adicional: monto, porcentaje, etc.
  serviceId           String?             // Para tipo = SERVICIO_GRATIS: servicio que se otorga
  couponId            String?             // Para tipo = CUPON: cupón del catálogo
  cantidadTotal       Int?                // null = ilimitado
  cantidadDisponible  Int?
  activa              Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  Negocio             Negocio             @relation(fields: [negocioId], references: [id])
  Coupon              Coupon?             @relation(fields: [couponId], references: [id])
  Service             Service?            @relation(fields: [serviceId], references: [id])
  LoyaltyRedemption   LoyaltyRedemption[]
}

model LoyaltyRedemption {
  id                     String             @id @default(cuid())
  negocioId              String
  userId                 String
  rewardId               String
  questId                String?            // ID de la misión si es recompensa de misión
  fechaExpiracion        DateTime?          // Fecha de expiración de la recompensa
  estado                 RewardStatus       @default(DISPONIBLE)
  claimCode              String?            @unique // Código de reclamación para premios manuales (ej. PX-8FK29Q)
  fechaEntrega           DateTime?
  staffId                String?
  notas                  String?
  // Campos de auditoría de entrega física y QR seguro
  claimToken             String?            @unique  // UUID interno y oculto para el código QR
  claimTokenExpiresAt    DateTime?          // Fecha de expiración temporal del código QR
  claimTokenRevokedAt    DateTime?          // Fecha en la que el QR fue revocado tras la entrega
  fechaSolicitud         DateTime?
  fechaRetiro            DateTime?
  scanCount              Int                @default(0) // Contador de escaneos/aperturas del QR
  entregadoPorId         String?            // userId o staffId que confirmó la entrega
  fechaEntregaConfirmada DateTime?
  observaciones          String?
  appointmentId          String?            // Para SERVICIO_GRATIS: reserva donde se usó
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  Negocio                Negocio            @relation(fields: [negocioId], references: [id])
  Usuario                Usuario            @relation(fields: [userId], references: [id])
  Reward                 LoyaltyReward      @relation(fields: [rewardId], references: [id])
  Staff                  Staff?             @relation(fields: [staffId], references: [id])
}

model RewardAudit {
  id             String   @id @default(cuid())
  rewardType     String   // PUNTOS | REFERIDO
  rewardId       String   // ID de la redención (LoyaltyRedemption o ReferralReward)
  claimCode      String?  // Código corto visible (ej. CTX-9F4K-PL)
  accion         String   // REQUESTED | SCANNED | READY | DELIVERED | TOKEN_EXPIRED | REGENERATED
  estadoAnterior String?  // Estado antes del cambio
  estadoNuevo    String?  // Estado después del cambio
  empleadoId     String?  // ID del staff/usuario que realizó la acción
  negocioId      String
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())

  Negocio        Negocio  @relation(fields: [negocioId], references: [id])
}

model Coupon {
  id                String        @id @default(cuid())
  negocioId         String
  codigo            String
  tipo              String        // PORCENTAJE | FIJO | SERVICIO | CATEGORIA | CUMPLEANOS | PRIMER_CLIENTE | VIP
  valor             Float
  servicioId        String?
  descripcion       String?
  fechaInicio       DateTime?
  fechaFin          DateTime?
  maxUsos           Int?
  usosActuales      Int           @default(0)
  maxUsosPorCliente Int?
  acumulable        Boolean       @default(false)
  activa            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Negocio           Negocio       @relation(fields: [negocioId], references: [id])
  CouponUsage       CouponUsage[]
  LoyaltyReward     LoyaltyReward[]
  ClientCoupon      ClientCoupon[]

  @@unique([negocioId, codigo])
}

model CouponUsage {
  id            String   @id @default(cuid())
  couponId      String
  userId        String
  appointmentId String?
  createdAt     DateTime @default(now())
  Coupon        Coupon   @relation(fields: [couponId], references: [id])
  Usuario       Usuario  @relation(fields: [userId], references: [id])
}

model ClientCoupon {
  id              String    @id @default(cuid())
  negocioId       String
  clienteId       String
  couponId        String
  questId         String?   // ID de la misión si es recompensa de misión
  sourceType      String    // LOYALTY_REWARD | QUEST | REFERRAL | CUMPLEANOS | MANUAL | AUTOMATIZACION
  sourceId        String?
  estado          String    @default("DISPONIBLE") // DISPONIBLE | RESERVADO | USADO | VENCIDO | CANCELADO
  codigo          String    @unique // Código único generado (ej. CTX-9A8X2)
  codigoOriginal  String    // Código del cupón original (ej. VISITA)
  nombre          String?
  descripcion     String?
  descuento       Float
  tipo            String    // PORCENTAJE | FIJO
  fechaAsignacion DateTime  @default(now())
  fechaExpiracion DateTime?
  fechaUso        DateTime?
  appointmentId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  Negocio         Negocio   @relation(fields: [negocioId], references: [id])
  Usuario         Usuario   @relation(fields: [clienteId], references: [id])
  Coupon          Coupon    @relation(fields: [couponId], references: [id])
}

model AutomationRule {
  id          String   @id @default(cuid())
  negocioId   String
  nombre      String
  descripcion String?
  disparador  String   // CUMPLEANOS | INACTIVIDAD | RESERVAS_COMPLETADAS | RECOMPENSA_GANADA | PUNTOS_ALCANZADOS | PRIMER_VISITA
  condiciones Json?    // { diasInactividad: 60 } | { reservasRequeridas: 10 } | { puntosRequeridos: 500 }
  acciones    Json     // [{ tipo: 'WHATSAPP', mensaje: '...' }, { tipo: 'PUNTOS', cantidad: 100 }, { tipo: 'CUPON', ... }]
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Negocio     Negocio  @relation(fields: [negocioId], references: [id])
}

model AutomationLog {
  id        String   @id @default(cuid())
  ruleId    String
  negocioId String
  userId    String
  detalles  String?
  estado    String   @default("OK") // OK | ERROR
  createdAt DateTime @default(now())
}

model Notification {
  id             String    @id @default(cuid())
  negocioId      String
  userId         String?   // Opcional si es global
  tipo           String    // RESERVA | PROMO | CAMPANA | PREMIO | REFERIDOS | AUTOMATIZACION | NOTICIA | SISTEMA | AVISO | RECORDATORIO
  categoria      String    // RESERVAS | PROMOCIONES | CAMPANAS | PREMIOS | NOTICIAS | SISTEMA | CUPONES
  titulo         String
  descripcion    String
  imagenUrl      String?
  icono          String?   // Nombre del icono de Lucide-React
  prioridad      String    @default("INFO") // INFO | SUCCESS | WARNING | ERROR
  recipientType  String    @default("USER") // ALL | USER | SEGMENT | VIP | INACTIVE | NEW_CLIENTS
  actionType     String?   // VER_RESERVA | VER_CAMPANA | VER_PROMO | VER_PREMIO | VER_PERFIL | ABRIR_URL | CUSTOM
  actionPayload  String?   // JSON string flexible (ej: {"screen": "campaign", "campaignId": "..."})
  metricas       String?   // JSON string para estadísticas (enviadas, entregadas, vistas, clics)
  leida          Boolean   @default(false)
  archived       Boolean   @default(false)
  fechaLectura   DateTime?
  scheduledFor   DateTime? // Para envíos programados en el futuro
  expiresAt      DateTime? // Fecha de expiración
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  Negocio        Negocio   @relation(fields: [negocioId], references: [id])
  Usuario        Usuario?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([negocioId])
  @@index([userId])
  @@index([leida])
  @@index([archived])
}

// ==========================================
// SISTEMA DE ROLES Y PERMISOS ENTERPRISE (SaaS)
// ==========================================

model AdminRole {
  id          String                 @id @default(uuid())
  nombre      String                 @unique
  descripcion String?
  color       String                 @default("#ec4899")
  icono       String                 @default("Shield")
  activo      Boolean                @default(true)
  jerarquia   Int                    @default(100)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  usuarios    AdminUser[]
  permisos    AdminRolePermission[]
  apiKeys     AdminApiKey[]
}

model AdminPermission {
  id          String                 @id @default(uuid())
  modulo      String
  accion      String
  codigo      String                 @unique
  nombre      String
  descripcion String?
  critico     Boolean                @default(false)
  roles       AdminRolePermission[]
}

model AdminRolePermission {
  rolId        String
  permisoId    String
  rol          AdminRole             @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso      AdminPermission       @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
}

model AdminTeam {
  id          String      @id @default(uuid())
  nombre      String      @unique
  descripcion String?
  color       String      @default("#6366f1")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  miembros    AdminUser[]
}

model AdminUser {
  id           String               @id @default(uuid())
  nombre       String
  apellido     String?
  email        String               @unique
  password     String
  activo       Boolean              @default(true)
  estado       String               @default("ACTIVO") // ACTIVO, SUSPENDIDO, VACACIONES, LICENCIA, PENDIENTE, BLOQUEADO, INVITADO
  avatar       String?
  scope        String               @default("GLOBAL") // GLOBAL, REGIONAL, NEGOCIOS_ASIGNADOS, PERSONAL
  cargo        String?
  telefono     String?
  rolId        String
  rol          AdminRole            @relation(fields: [rolId], references: [id])
  equipoId     String?
  equipo       AdminTeam?           @relation(fields: [equipoId], references: [id])
  ultimaAccion DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  negociosAsignados AdminUserNegocio[]
  loginHistory      AdminLoginHistory[]
  auditLogs         AdminAuditLog[]
  comunicaciones    GlobalCommunication[]
}

model AdminUserNegocio {
  adminUserId  String
  negocioId    String
  adminUser    AdminUser             @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  negocio      Negocio               @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@id([adminUserId, negocioId])
}

model AdminLoginHistory {
  id               String    @id @default(uuid())
  adminUserId      String
  adminUser        AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  fecha            DateTime  @default(now())
  ip               String?
  pais             String?
  ciudad           String?
  navegador        String?
  sistemaOperativo String?
  dispositivo      String?
  resultado        String
  duracionMinutos  Int?
  logoutAt         DateTime?
}

model AdminAuditLog {
  id          String    @id @default(uuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  fecha       DateTime  @default(now())
  accion      String
  modulo      String
  descripcion String?
  targetId    String?
  targetType  String?
  datosAntes  String?   // JSON serializado
  datosDespues String?  // JSON serializado
  ipAddress   String?
  resultado   String    @default("EXITOSO")
}

model AdminApiKey {
  id          String    @id @default(uuid())
  nombre      String
  keyHash     String    @unique
  activo      Boolean   @default(true)
  rolId       String
  rol         AdminRole @relation(fields: [rolId], references: [id])
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
}

// ─── COMMUNICATIONS HUB MODELS ───

model GlobalCommunication {
  id              String                         @id @default(uuid())
  titulo          String
  subtitulo       String?
  contenido       String                         // HTML/Markdown enriquecido
  imagenUrl       String?
  videoUrl        String?
  icono           String?                        // Icono de Lucide
  color           String?                        // Color hexadecimal acento
  prioridad       String                         @default("INFO") // INFO | SUCCESS | WARNING | ERROR
  tipo            String                         // SISTEMA | NOTICIA | PROMO | MANTENIMIENTO | SEGURIDAD | CONSEJOS | RECORDATORIO | etc.
  estado          String                         @default("BORRADOR") // BORRADOR | PROGRAMADO | ENVIANDO | ENVIADO | CANCELADO
  destinatarios   String                         // Filtros JSON: { type: "ALL", planId: "...", city: "..." }
  canales         String                         // Array JSON: ["APP", "PUSH", "WHATSAPP", "EMAIL", "SMS", "BANNER", "POPUP"]
  popupConfig     String?                        // Configuración JSON para emergentes (rango fechas, mostrar una vez, versión, etc.)
  scheduledFor    DateTime?                      // Fecha programada
  sentAt          DateTime?                      // Fecha real de envío
  repeatType      String                         @default("NONE") // NONE | DAILY | WEEKLY | MONTHLY | YEARLY
  timeZone        String                         @default("America/Bogota")
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  autorId         String
  autor           AdminUser                      @relation(fields: [autorId], references: [id])
  destinatariosLog GlobalCommunicationRecipient[]
  analiticas      GlobalCommunicationAnalytics?
  
  @@index([estado])
  @@index([tipo])
}

model GlobalCommunicationRecipient {
  id              String              @id @default(uuid())
  communicationId String
  communication   GlobalCommunication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  negocioId       String?
  userId          String?             // Usuario.id o AdminUser.id
  canal           String              // APP | PUSH | WHATSAPP | EMAIL | SMS | BANNER | POPUP
  estado          String              @default("ENVIADO") // ENVIADO | ENTREGADO | LEIDO | CLIC | CONVERTIDO | ERROR
  errorDetail     String?
  fechaEntrega    DateTime?
  fechaLectura    DateTime?
  fechaClic       DateTime?
  fechaConversion DateTime?
  createdAt       DateTime            @default(now())
  
  @@index([communicationId])
  @@index([negocioId])
  @@index([userId])
  @@index([estado])
}

model GlobalCommunicationAnalytics {
  id              String              @id @default(uuid())
  communicationId String              @unique
  communication   GlobalCommunication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  enviados        Int                 @default(0)
  entregados      Int                 @default(0)
  abiertos        Int                 @default(0)
  clicks          Int                 @default(0)
  conversiones    Int                 @default(0)
  ctr             Float               @default(0.0)
  conversionRate  Float               @default(0.0)
  errores         Int                 @default(0)
  cancelados      Int                 @default(0)
  tiempoAperturaPromedio Float       @default(0.0)
  negociosAlcanzados     Int         @default(0)
  clientesAlcanzados     Int         @default(0)
  updatedAt       DateTime            @updatedAt
}

model HelpCenterItem {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String?
  contenido   String
  tipo        String   // TUTORIAL | MANUAL | VIDEO | FAQ | DOC | GUIA | RECURSO
  categoria   String   // Categoría de ayuda
  urlRecurso  String?  // Link externo (ej: youtube, pdf, etc.)
  activo      Boolean  @default(true)
  vistas      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChangelogItem {
  id          String   @id @default(uuid())
  version     String   // Ej: "v2.5"
  titulo      String
  descripcion String?
  cambios     String   // Array JSON serializado
  activo      Boolean  @default(true)
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SharedMedia {
  id          String   @id @default(uuid())
  nombre      String
  url         String
  tipo        String   // IMAGE | VIDEO | PDF | LOGO | ICON | BANNER | FILE
  sizeBytes   Int?
  createdAt   DateTime @default(now())
}

model CommunicationTemplate {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  titulo      String
  subtitulo   String?
  contenido   String
  imagenUrl   String?
  videoUrl    String?
  icono       String?
  color       String?
  tipo        String
  canales     String   // Array JSON serializado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
